{
  "name": "nyancat-desktop",
  "version": "1.0.0",
  "description": "Free open-source pixel cat desktop companion",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --arm64",
    "build:win": "electron-builder --win --x64",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.vansh.nyancat-desktop",
    "productName": "NyanCat Desktop",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": true
    }
  },
  "dependencies": {
    "electron": "^35.0.0",
    "node-global-key-listener": "^0.3.0"
  },
  "devDependencies": {
    "electron-builder": "^24.0.0"
  }
}
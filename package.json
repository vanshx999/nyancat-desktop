{
  "name": "nyancat-desktop",
  "version": "1.0.0",
  "description": "Free open-source pixel cat desktop companion",
  "author": "Vansh",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac --arm64 --x64",
    "build:win": "electron-builder --win --x64"
  },

  "build": {
    "appId": "com.vansh.nyancat-desktop",
    "productName": "NyanCat Desktop",
    "icon": "assets/icon",
    
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],

    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["arm64", "x64"]
        }
      ]
    },

    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },

    "nsis": {
      "oneClick": true,
      "deleteAppDataOnUninstall": true
    }
  },

  "dependencies": {
    "node-global-key-listener": "^0.3.0"
  },

  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^24.0.0"
  }
}